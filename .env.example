# Переменные окружения для локальной разработки
# НЕ ЗАГРУЖАЙТЕ ЭТОТ ФАЙЛ В GIT!

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=ваш_токен_бота_здесь

# --- Web App ---
# URL веб-приложения (используется для формирования ссылки /login в Telegram)
# Пример: https://your-domain.up.railway.app
WEB_APP_URL=http://localhost:5000

# Разрешенные origin для CORS (через запятую).
# Если оставить пустым - будет использован WEB_APP_URL и localhost.
WEB_ALLOWED_ORIGINS=http://localhost:5000

# --- Web session (JWT) ---
# Секрет для подписи сессионных токенов (замените на свой)
WEB_SESSION_SECRET=change-me
# Срок жизни сессии в секундах (по умолчанию 30 дней)
WEB_SESSION_TTL=2592000
# Cookie secure mode: auto|true|false (на Railway обычно auto/true)
WEB_COOKIE_SECURE=auto

# --- Database ---
# По умолчанию используется SQLite: data/spotify_bot.db
# DATABASE_URL=sqlite+aiosqlite:///absolute/path/to/spotify_bot.db
DATABASE_URL=

# --- Telegram Storage / backups ---
STORAGE_CHANNEL_ID=-1003748020768

# --- YouTube cookies for yt-dlp ---
# ВАЖНО: передавайте именно Netscape cookies.txt в base64 (одной строкой).
# Пример: YOUTUBE_COOKIES_BASE64=base64_of_cookies.txt
YOUTUBE_COOKIES_BASE64=

# --- Legal fallback (после ошибки yt-dlp): Jamendo, Archive, опционально FMA ---
# Client ID: https://developer.jamendo.com (создайте приложение, скопируйте Client ID)
JAMENDO_CLIENT_ID=
# Не обязателен для текущего кода (нужен только для OAuth Jamendo «от пользователя»)
JAMENDO_CLIENT_SECRET=
# Опционально: свой endpoint с плейсхолдером {query} (будет URL-encoded)
# Пример: https://example.com/api/audio-search?q={query}
FMA_FALLBACK_URL_TEMPLATE=
# Source routing
DOWNLOAD_SOURCE_PRIORITY=youtube,jamendo,archive,fma,ccmixter
SOURCE_ENABLE_YOUTUBE=1
SOURCE_ENABLE_JAMENDO=1
SOURCE_ENABLE_ARCHIVE=1
SOURCE_ENABLE_FMA=1
SOURCE_ENABLE_CCMIXTER=1

# --- Rate limits (simple, in-memory; adjust if needed) ---
DOWNLOAD_RATE_LIMIT=10
DOWNLOAD_RATE_PERIOD_SECONDS=600
PREPARE_STREAM_RATE_LIMIT=0
PREPARE_STREAM_RATE_PERIOD_SECONDS=600
SYNC_RATE_LIMIT=1
SYNC_RATE_PERIOD_SECONDS=3600
BACKUP_RATE_LIMIT=1
BACKUP_RATE_PERIOD_SECONDS=600
